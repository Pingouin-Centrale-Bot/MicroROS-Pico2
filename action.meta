{
    "names": {
        "rmw_microxrcedds": {
            "cmake-args": [
                "-DRMW_UXRCE_MAX_NODES=2",
                "-DRMW_UXRCE_MAX_PUBLISHERS=10",
                "-DRMW_UXRCE_MAX_SUBSCRIPTIONS=10",
                "-DRMW_UXRCE_MAX_SERVICES=10",
                "-DRMW_UXRCE_MAX_CLIENTS=2",
                "-DRMW_UXRCE_MAX_HISTORY=2",
                "-DRMW_UXRCE_MAX_PARAMETERS=10",
            ]
        },
        "rclc_parameter": {
            "cmake-args": [
                "-DRCLC_PARAMETER_MAX_STRING_LENGTH=32"
            ]
        }
    }
}